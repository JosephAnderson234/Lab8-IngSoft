[run]
source = src/rewards
branch = True
relative_files = True
omit =
    */__init__.py
    src/rewards/apps/productor_restaurante.py
    src/rewards/apps/consumidor_recompensas.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.

[xml]
output = coverage.xml
